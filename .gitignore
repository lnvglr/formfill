# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets; example template is allowed
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / local tooling (may contain project-specific IDs)
.cursor/
.mcp.json

# Cursor agent skills (local tooling, not app source)
.agents/
skills-lock.json

# Supabase CLI cache
supabase/.temp/

# Railway local link config
.railway/
