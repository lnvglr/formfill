# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Passkeys (WebAuthn) — enable in Supabase Dashboard:
# Authentication → Passkeys → Enable, set RP ID to your domain (e.g. localhost for dev)
# and origins (e.g. http://localhost:3000). No Apple Developer account needed for web.
#
# Anonymous sign-ins (guest mode) — enable in Supabase Dashboard:
# Authentication → Providers → Anonymous sign-ins → Enable

# ── AI Provider ──────────────────────────────────────────────
# Options: anthropic | huggingface
# If unset, auto-picks huggingface when HF_TOKEN/HF_BASE_URL is set, else anthropic.
AI_PROVIDER=huggingface

# ── Anthropic (production) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Hugging Face (cheap/free testing) ─────────────────────────
# Token with "Inference Providers" permission enabled:
# https://huggingface.co/settings/tokens
# Enable providers: https://huggingface.co/settings/inference-providers
HF_TOKEN=hf_...
# Models must be available on your enabled providers (not every HF model works).
# Good defaults for structured JSON: meta-llama/Llama-3.3-70B-Instruct, Qwen/Qwen3-14B
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct
# Optional routing: fastest (default) | cheapest | preferred | groq | together ...
# HF_POLICY=fastest
# Cloud router:
HF_BASE_URL=https://router.huggingface.co/v1
# Local TGI / vLLM / llama.cpp with OpenAI-compatible API:
# HF_BASE_URL=http://localhost:8080/v1
# HF_TOKEN=   # not needed for most local servers

# ── App URL (Stripe redirects) ─────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products/prices in Stripe Dashboard, then paste price IDs:
STRIPE_PRICE_CREDITS_10=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...

# ── Supabase secret key (server-only, admin + webhooks) ──────
# Dashboard → Project Settings → API Keys → Secret keys (sb_secret_…)
# Preferred over the legacy service_role JWT (deprecated end of 2026).
SUPABASE_SECRET_KEY=sb_secret_...
# Legacy fallback — Dashboard → API Keys → Legacy API Keys → service_role
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Comma-separated emails that become super_admin on login:
SUPER_ADMIN_EMAILS=you@example.com
